int get_next_prime(int currentPrime) {
  int index = 0;
  while (currentPrime >= PRIME_NUMBERS[index]) {
    currentPrime = PRIME_NUMBERS[index];
    index++;
  };
  printf("The prime number selected is: %d", PRIME_NUMBERS[index]);
  return PRIME_NUMBERS[index];
}

struct Node {
  struct Node *next;
  char *key;
  int value;
};

struct HashTable {
  struct Node *buckets;
  int size;
};

unsigned int hash_function(int table_size, char *key) {
  printf("The size of the table is : %d\n", table_size);
  printf("The key is %s\n", key);
  if (key == NULL) {
    return 0;
  }
  if (table_size < 1) {
    return 0;
  }
  unsigned int hash = 5381;
  int c;

  while ((c = *key++)) {
    // hash * 33 + c
    hash = ((hash << 5) + hash) + c;
  }
  printf("Final hash before modulo: %u\n", hash); // DEBUG
  unsigned int result = hash % table_size;
  printf("After modulo %d: %u\n", table_size, result); // DEBUG

  return result;
  // make sure the hash ranges within the table size;
  // return hash % table_size;
}

struct HashTable *HT_init() {
  struct HashTable *hashTable = malloc(sizeof(struct HashTable));

  if (hashTable == NULL) {
    return NULL;
  }

  hashTable->buckets = malloc(sizeof(struct Node));
  hashTable->size = get_next_prime(53);

  return hashTable;
};

int HT_Put(struct HashTable *hashTable, char *key, int value) {
  // Hash the value
  int hashValue = hash_function(hashTable->size, key);
  printf("The hashvalue for %s is : %d\n", key, hashValue);
