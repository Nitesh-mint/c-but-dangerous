// Implementation of HashTable in C.
// HashTable has the same concept as dynamic array
// it has Table and collection of nodes to store the key and value.
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct Node {
  struct Node *next;
  char *key;
  int value;
};

struct HashTable {
  struct Node **buckets;
  int size;
  int count;
};

static const int PRIME_NUMBERS[] = {
    53,        // Tiny tables
    97,        // Very small
    193,       // Small
    389,       // Small-medium
    769,       // Medium
    1543,      // Medium-large
    3079,      // Large
    6151,      // Larger
    12289,     // Even larger
    24593,     //
    49157,     //
    98317,     //
    196613,    //
    393241,    //
    786433,    //
    1572869,   //
    3145739,   //
    6291469,   //
    12582917,  //
    25165843,  //
    50331653,  //
    100663319, //
    201326611, //
    402653189, //
    805306457, //
    1610612741 // Max for 32-bit
};

int get_next_prime(int currentPrime) {
  int PrimeArraySize = sizeof(PRIME_NUMBERS) / sizeof(PRIME_NUMBERS[0]);
  int index = 0;
  while (currentPrime >= PRIME_NUMBERS[index] && index < PrimeArraySize) {
    index++;
  };
  if (index < PrimeArraySize) {
    return PRIME_NUMBERS[index];
  }
  return 0;
}

unsigned int get_hash_value(int table_size, char *key) {
  if (key == NULL) {
    return 0;
  }
  if (table_size < 1) {
    return 0;
  }
  unsigned int hash = 5381;
  int c;

  while ((c = *key++)) {
    // hash * 33 + c
    hash = ((hash << 5) + hash) + c;
  }
  unsigned int result = hash % table_size;
  return result;
};

void HT_Put(struct HashTable *hashTable, char *key, int value) {
  float load = (float)hashTable->count / hashTable->size;

  if (load > 0.75) {
    // resize the hashTable;
  }

  // Hash the value
  int hashValue = get_hash_value(hashTable->size, key);

  struct Node *current = hashTable->buckets[hashValue];

  while (current != NULL) {
    // update the value if the key already has values;
    if (strcmp(current->key, key) == 0) {
      current->value = value;
      return;
    }
    current = current->next;
  }

  struct Node *newNode = malloc(sizeof(struct Node));

  newNode->key = strdup(key);
  newNode->value = value;
  // make the currently inserted node move to the first and shift others by one
  // step.
  newNode->next = hashTable->buckets[hashValue];
  hashTable->buckets[hashValue] = newNode;
  hashTable->count++;
};

struct HashTable *HT_init(unsigned int tableSize) {
  struct HashTable *hashTable = malloc(sizeof(struct HashTable));
  if (hashTable == NULL) {
    return NULL;
  }
  hashTable->size = get_next_prime(tableSize);
  // allocate memory for pointers and set the value to NULL or 0;
  hashTable->buckets = calloc(hashTable->size, sizeof(struct Node *));
  return hashTable;
};

void HT_Destroy(struct HashTable *hashTable) {
  if (hashTable != NULL) {
    for (int i = 0; i < hashTable->size; i++) {

      struct Node *current = hashTable->buckets[i];

      while (current != NULL) {
        struct Node *next = current->next;

        free(current->key);
        free(current);
        current = next;
      }
    }
    free(hashTable->buckets);
    free(hashTable);
    printf("Succesfully freed the hashTable");
  };
};

int HT_Rehash(struct HashTable *hashTable) {
  int newTableSize = get_next_prime(hashTable->size);

  struct HashTable *newHashTable = HT_init(newTableSize);

  for (int i = 0; i < hashTable->size; i++) {
    struct Node *current = hashTable->buckets[i];
    while (current != NULL) {
      HT_Put(newHashTable, current->key, current->value);
      current = current->next;
    }
  }

  HT_Destroy(hashTable);

  printf("Succesfully rehashed the table to new table");

  return 1;
};

int HT_Get(struct HashTable *hashTable, char *key) {
  int hashValue = get_hash_value(hashTable->size, key);
  struct Node *current = hashTable->buckets[hashValue];
  while (current != NULL) {
    if (current->key != NULL && strcmp(current->key, key) == 0) {
      printf("The value for %s is %d\n", key, current->value);
      return current->value;
    }
    current = current->next;
  }
  printf("Key %s not found\n", key);
  return -1;
};

int HT_Delete(struct HashTable *hashTable, char *key) {
  int index = get_hash_value(hashTable->size, key);
  struct Node *current = hashTable->buckets[index];
  struct Node *prev = NULL;
  // [cat, dog, pig]
  while (current != NULL) {
    if (strcmp(current->key, key) == 0) {
      if (prev == NULL) {
        // delete cat? point to the dog and free the cat memory;
        hashTable->buckets[index] = current->next;
      } else {
        // delete dog? point cat -> pig and free the current(dog);
        prev->next = current->next;
      }
      free(current->key);
      free(current);
      hashTable->count--;
      printf("Succesfully deleted %s\n", key);
      return 1;
    }
    prev = current;
    current = current->next;
  };

  return -1;
};

int main(void) {
  struct HashTable *hashTable = HT_init(0);
  HT_Put(hashTable, "Supriya", 1);
  HT_Put(hashTable, "Nitesh", 2);
  HT_Put(hashTable, "Supriya", 10);
  HT_Get(hashTable, "Supriya");
  HT_Get(hashTable, "Doesn't Exist");
  HT_Delete(hashTable, "Nitesh");
  HT_Get(hashTable, "Nitesh");
  HT_Get(hashTable, "Supriya");
  HT_Rehash(hashTable);
  return 0;
}
